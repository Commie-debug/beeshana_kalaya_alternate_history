    Q.india_tamil_support_2 = Q.india_tamil_support.toFixed(1);
}
if (Q.tamil_nadu_tamil_support) {
    Q.tamil_nadu_tamil_support_2 = Q.tamil_nadu_tamil_support.toFixed(1);
}
if (Q.ipkf_morale) {
    Q.ipkf_morale_2 = Q.ipkf_morale.toFixed(1);
}
!}

