@politics
on-arrival: {!
Q.coalition_count = Q.active_coalitions ? Q.active_coalitions.length : 0;

for (var i = 0; i < 8; i++) {
    var c = Q.active_coalitions && Q.active_coalitions[i];
    if (c) {
        Q['c' + i + '_name'] = c.name || '';
        Q['c' + i + '_lead'] = c.lead || '';
        Q['c' + i + '_color'] = Q.partyColors[c.lead] || '#666';
        
        var isGov = (Q.current_gov && Q.current_gov.indexOf(c.lead) !== -1);
        var csVar = c.lead.toLowerCase() + '_providing_cs';
        var isCS = Q[csVar] === 1;
        
        if (isGov) {
            Q['c' + i + '_status'] = '● Gov';
            Q['c' + i + '_statcol'] = '#4CAF50';
        } else if (isCS) {
            Q['c' + i + '_status'] = '◐ C&S';
            Q['c' + i + '_statcol'] = '#FF9800';
        } else {
            Q['c' + i + '_status'] = '○ Opp';
            Q['c' + i + '_statcol'] = '#9E9E9E';
        }
        
        Q['c' + i + '_members'] = c.members ? c.members.join(', ') : '';
    } else {
        Q['c' + i + '_name'] = ''; Q['c' + i + '_members'] = '';
    }
}
!}

